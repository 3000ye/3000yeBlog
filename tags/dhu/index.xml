&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">\begin&lt;/span>&lt;span class="nb">{&lt;/span>minipage&lt;span class="nb">}&lt;/span>[c]&lt;span class="nb">{&lt;/span>0.45&lt;span class="k">\textwidth&lt;/span>&lt;span class="nb">}&lt;/span>
