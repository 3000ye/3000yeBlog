&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">D_j&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> Number of pollinating bees required for flower pollination &lt;span class="k">\\&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">T_k&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> Honeycomb size grade, &lt;span class="s">$&lt;/span>&lt;span class="nb">k &lt;/span>&lt;span class="o">=&lt;/span>&lt;span class="nb"> &lt;/span>&lt;span class="m">1&lt;/span>&lt;span class="nb">, &lt;/span>&lt;span class="m">2&lt;/span>&lt;span class="nb">, &lt;/span>&lt;span class="nv">\cdots&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="k">\\&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">B&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> Maximum number of hive &lt;span class="k">\\&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">R_{ik}&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> Maximum influence radius of a single honeycomb &lt;span class="k">\\&lt;/span>
