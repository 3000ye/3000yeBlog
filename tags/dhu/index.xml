&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="k">\midrule&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">t&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> &lt;span class="s">$&lt;/span>&lt;span class="nb">t_{th}&lt;/span>&lt;span class="s">$&lt;/span> year &lt;span class="nb">&amp;amp;&lt;/span> &lt;span class="s">$&lt;/span>&lt;span class="nv">\sim&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="k">\\&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">e_k&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> the error term &lt;span class="nb">&amp;amp;&lt;/span> &lt;span class="s">$&lt;/span>&lt;span class="nv">\sim&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="k">\\&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="s">$&lt;/span>&lt;span class="nb">X_{ij}&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="nb">&amp;amp;&lt;/span> Raw data matrix &lt;span class="nb">&amp;amp;&lt;/span> &lt;span class="s">$&lt;/span>&lt;span class="nv">\sim&lt;/span>&lt;span class="s">$&lt;/span> &lt;span class="k">\\&lt;/span>
