&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c">&lt;/span> &lt;span class="k">\label&lt;/span>&lt;span class="nb">{&lt;/span>tab: 一个表&lt;span class="nb">}&lt;/span>&lt;span class="c">%
&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c">&lt;/span>&lt;span class="k">\end&lt;/span>&lt;span class="nb">{&lt;/span>table&lt;span class="nb">}&lt;/span>&lt;span class="c">%
&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
